{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vel.local/schemas/self-model-envelope.schema.json",
  "title": "Vel Self-Model Envelope",
  "description": "Canonical envelope for repository-aware introspection and supervised self-modification tasks.",
  "type": "object",
  "properties": {
    "active_task": {
      "type": "string",
      "minLength": 1
    },
    "authority_docs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "relevant_tickets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "read_scopes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "write_scopes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_checks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_gate": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "active_task",
    "authority_docs",
    "read_scopes",
    "write_scopes",
    "required_checks",
    "review_gate"
  ],
  "additionalProperties": false
}
