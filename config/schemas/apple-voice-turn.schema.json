{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vel.local/schemas/apple-voice-turn.schema.json",
  "title": "AppleVoiceTurnResponse",
  "description": "Canonical Phase 07 Apple voice-turn request and response contract for backend-owned voice loops.",
  "type": "object",
  "$defs": {
    "AppleClientSurface": {
      "type": "string",
      "enum": [
        "ios_voice",
        "ios_capture",
        "watch_briefing",
        "watch_quick_action",
        "mac_context"
      ]
    },
    "AppleRequestedOperation": {
      "type": "string",
      "enum": [
        "capture_only",
        "query_only",
        "capture_and_query",
        "mutation"
      ]
    },
    "AppleVoiceIntent": {
      "type": "string",
      "enum": [
        "capture",
        "morning_briefing",
        "current_schedule",
        "next_commitment",
        "active_nudges",
        "explain_why",
        "behavior_summary",
        "complete_commitment",
        "snooze_nudge"
      ]
    },
    "AppleResponseMode": {
      "type": "string",
      "enum": [
        "spoken_summary",
        "card",
        "confirmation",
        "clarification_required"
      ]
    },
    "AppleTurnProvenance": {
      "type": "object",
      "properties": {
        "source_device": { "type": ["string", "null"] },
        "locale": { "type": ["string", "null"] },
        "transcript_origin": { "type": ["string", "null"] },
        "recorded_at": { "type": ["string", "null"], "format": "date-time" },
        "offline_captured_at": { "type": ["string", "null"], "format": "date-time" },
        "queued_at": { "type": ["string", "null"], "format": "date-time" }
      },
      "required": [
        "source_device",
        "locale",
        "transcript_origin",
        "recorded_at",
        "offline_captured_at",
        "queued_at"
      ],
      "additionalProperties": false
    },
    "AppleVoiceTurnRequest": {
      "type": "object",
      "properties": {
        "transcript": { "type": "string", "minLength": 1 },
        "surface": { "$ref": "#/$defs/AppleClientSurface" },
        "operation": { "$ref": "#/$defs/AppleRequestedOperation" },
        "intents": {
          "type": "array",
          "items": { "$ref": "#/$defs/AppleVoiceIntent" }
        },
        "provenance": {
          "oneOf": [
            { "$ref": "#/$defs/AppleTurnProvenance" },
            { "type": "null" }
          ]
        }
      },
      "required": ["transcript", "surface", "operation", "intents", "provenance"],
      "additionalProperties": false
    },
    "AppleResponseEvidence": {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "detail": { "type": "string", "minLength": 1 },
        "source_id": { "type": ["string", "null"] }
      },
      "required": ["kind", "label", "detail", "source_id"],
      "additionalProperties": false
    },
    "AppleVoiceTurnQueuedMutationSummary": {
      "type": "object",
      "properties": {
        "mutation_kind": { "type": "string", "minLength": 1 },
        "queued": { "type": "boolean" },
        "summary": { "type": "string", "minLength": 1 },
        "action_reference_id": { "type": ["string", "null"] }
      },
      "required": ["mutation_kind", "queued", "summary", "action_reference_id"],
      "additionalProperties": false
    },
    "AppleScheduleEvent": {
      "type": "object",
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "start_ts": { "type": "integer" },
        "end_ts": { "type": ["integer", "null"] },
        "location": { "type": ["string", "null"] },
        "leave_by_ts": { "type": ["integer", "null"] }
      },
      "required": ["title", "start_ts", "end_ts", "location", "leave_by_ts"],
      "additionalProperties": false
    },
    "AppleScheduleSnapshot": {
      "type": "object",
      "properties": {
        "generated_at": { "type": "integer" },
        "timezone": { "type": "string", "minLength": 1 },
        "focus_summary": { "type": ["string", "null"] },
        "next_event": {
          "oneOf": [
            { "$ref": "#/$defs/AppleScheduleEvent" },
            { "type": "null" }
          ]
        },
        "upcoming_events": {
          "type": "array",
          "items": { "$ref": "#/$defs/AppleScheduleEvent" }
        },
        "reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "required": [
        "generated_at",
        "timezone",
        "focus_summary",
        "next_event",
        "upcoming_events",
        "reasons"
      ],
      "additionalProperties": false
    },
    "AppleBehaviorMetric": {
      "type": "object",
      "properties": {
        "metric_key": {
          "type": "string",
          "enum": ["step_count", "stand_hours", "exercise_minutes"]
        },
        "display_label": { "type": "string", "minLength": 1 },
        "value": { "type": "number" },
        "unit": { "type": "string", "minLength": 1 },
        "recorded_at": { "type": "integer" },
        "reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "required": [
        "metric_key",
        "display_label",
        "value",
        "unit",
        "recorded_at",
        "reasons"
      ],
      "additionalProperties": false
    },
    "AppleBehaviorSummary": {
      "type": "object",
      "properties": {
        "generated_at": { "type": "integer" },
        "timezone": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "enum": ["daily"] },
        "headline": { "type": "string", "minLength": 1 },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/AppleBehaviorMetric" }
        },
        "reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "freshness_seconds": { "type": ["integer", "null"] }
      },
      "required": [
        "generated_at",
        "timezone",
        "scope",
        "headline",
        "metrics",
        "reasons",
        "freshness_seconds"
      ],
      "additionalProperties": false
    }
  },
  "properties": {
    "request": { "$ref": "#/$defs/AppleVoiceTurnRequest" },
    "response": {
      "type": "object",
      "properties": {
        "operation": { "$ref": "#/$defs/AppleRequestedOperation" },
        "mode": { "$ref": "#/$defs/AppleResponseMode" },
        "summary": { "type": "string", "minLength": 1 },
        "capture_id": {
          "type": ["string", "null"],
          "pattern": "^cap_[A-Za-z0-9_]+$"
        },
        "reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/AppleResponseEvidence" }
        },
        "queued_mutation": {
          "oneOf": [
            { "$ref": "#/$defs/AppleVoiceTurnQueuedMutationSummary" },
            { "type": "null" }
          ]
        },
        "schedule": {
          "oneOf": [
            { "$ref": "#/$defs/AppleScheduleSnapshot" },
            { "type": "null" }
          ]
        },
        "behavior_summary": {
          "oneOf": [
            { "$ref": "#/$defs/AppleBehaviorSummary" },
            { "type": "null" }
          ]
        }
      },
      "required": [
        "operation",
        "mode",
        "summary",
        "capture_id",
        "reasons",
        "evidence",
        "queued_mutation",
        "schedule",
        "behavior_summary"
      ],
      "additionalProperties": false
    }
  },
  "required": ["request", "response"],
  "additionalProperties": false
}
