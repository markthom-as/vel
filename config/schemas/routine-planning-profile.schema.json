{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vel.local/schemas/routine-planning-profile.schema.json",
  "title": "RoutinePlanningProfile",
  "type": "object",
  "description": "Durable backend-owned routine blocks and bounded planning constraints that shape same-day day planning.",
  "additionalProperties": false,
  "$defs": {
    "RoutineBlockSourceKind": {
      "type": "string",
      "enum": ["operator_declared", "inferred", "imported"]
    },
    "ScheduleTimeWindow": {
      "type": "string",
      "enum": ["prenoon", "afternoon", "evening", "night", "day"]
    },
    "DurableRoutineBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "source",
        "local_timezone",
        "start_local_time",
        "end_local_time",
        "days_of_week",
        "protected",
        "active"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "source": { "$ref": "#/$defs/RoutineBlockSourceKind" },
        "local_timezone": { "type": "string", "minLength": 1 },
        "start_local_time": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" },
        "end_local_time": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" },
        "days_of_week": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1, "maximum": 7 }
        },
        "protected": { "type": "boolean" },
        "active": { "type": "boolean" }
      }
    },
    "PlanningConstraintKind": {
      "type": "string",
      "enum": [
        "max_scheduled_items",
        "reserve_buffer_before_calendar",
        "reserve_buffer_after_calendar",
        "default_time_window",
        "require_judgment_for_overflow"
      ]
    },
    "PlanningConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "kind", "active"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "kind": { "$ref": "#/$defs/PlanningConstraintKind" },
        "detail": { "type": ["string", "null"] },
        "time_window": {
          "anyOf": [
            { "$ref": "#/$defs/ScheduleTimeWindow" },
            { "type": "null" }
          ]
        },
        "minutes": { "type": ["integer", "null"], "minimum": 0 },
        "max_items": { "type": ["integer", "null"], "minimum": 0 },
        "active": { "type": "boolean" }
      }
    }
  },
  "required": ["routine_blocks", "planning_constraints"],
  "properties": {
    "routine_blocks": {
      "type": "array",
      "items": { "$ref": "#/$defs/DurableRoutineBlock" }
    },
    "planning_constraints": {
      "type": "array",
      "items": { "$ref": "#/$defs/PlanningConstraint" }
    }
  }
}
