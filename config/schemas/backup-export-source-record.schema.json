{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vel.local/schemas/backup-export-source-record.schema.json",
  "title": "BackupExportSourceRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_kind",
    "source_family",
    "provider_key",
    "source_mode",
    "source_path",
    "external_id",
    "account_ref",
    "record_timestamp",
    "normalized_at",
    "content_hash",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "record_kind": {
      "type": "string",
      "minLength": 1
    },
    "source_family": {
      "type": "string",
      "minLength": 1
    },
    "provider_key": {
      "type": "string",
      "minLength": 1
    },
    "source_mode": {
      "type": "string",
      "minLength": 1
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "external_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "account_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "record_timestamp": {
      "type": [
        "string",
        "null"
      ]
    },
    "normalized_at": {
      "type": "string",
      "format": "date-time"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "payload": {
      "type": "object"
    }
  }
}
