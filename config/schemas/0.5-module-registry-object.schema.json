{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vel.local/schemas/0.5-module-registry-object.schema.json",
  "title": "0.5 Module Registry Object",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "namespace",
    "slug",
    "display_name",
    "version",
    "status",
    "manifest_ref"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^module\\.[a-z0-9-]+\\.[a-z0-9-]+$"
    },
    "namespace": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "deprecated",
        "disabled"
      ]
    },
    "manifest_ref": {
      "type": "string",
      "minLength": 1
    },
    "capability_requests": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "overlay": {
      "type": "object"
    }
  }
}
